@inherits LayoutComponentBase

<div class="d-flex flex-column min-vh-100">
    <header class="site-header border-bottom">
        <div class="container py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
            <a class="site-brand fw-bold text-decoration-none fs-5" href="/">Scam<span>Alert</span></a>
            <NavMenu />
        </div>
    </header>
    <main class="container py-4 flex-grow-1">
        @Body
    </main>
    <SiteFooter />
    <CookieConsentBanner @rendermode="new InteractiveServerRenderMode(prerender: false)" />
</div>
