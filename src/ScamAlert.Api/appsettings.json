{
  "ConnectionStrings": {
    "ScamAlertDb": "Data Source=scamalert.db"
  },
  "Alerts": {
    "EscalationDelaySeconds": 120,
    "EscalationPollIntervalSeconds": 30
  },
  "Twilio": {
    "AccountSid": "",
    "AuthToken": "",
    "FromPhoneNumber": "",
    "StatusCallbackBaseUrl": "https://your-public-host/api/webhooks/twilio/status",
    "ValidateWebhookSignatures": true,
    "WebhookPublicBaseUrl": "https://your-public-host"
  },
  "Authentication": {
    "Provider": "JwtBearer",
    "Jwt": {
      "Issuer": "ScamAlert.Api",
      "Audience": "ScamAlert.Client",
      "SigningKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_32CHARS_MIN",
      "AccessTokenMinutes": 60,
      "RequireHttpsMetadata": true
    },
    "Lockout": {
      "MaxFailedAttempts": 5,
      "LockoutMinutes": 15
    },
    "BootstrapAdmin": {
      "Enabled": false,
      "Username": "",
      "Password": "",
      "Roles": [ "admin", "operator" ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
