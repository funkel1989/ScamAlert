{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "BootstrapAdmin": {
      "Enabled": false
    },
    "Jwt": {
      "RequireHttpsMetadata": true
    }
  },
  "Stripe": {
    "SkipPaymentForDevelopment": false
  },
  "Twilio": {
    "ValidateWebhookSignatures": true
  }
}
