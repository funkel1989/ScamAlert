@page "/devices"
@attribute [Authorize]
@rendermode InteractiveServer
@inherits PortalPageBase

<PageTitle>Protected devices</PageTitle>

<h1 class="h3 mb-4">Protected devices</h1>

@if (!PortalReady)
{
    <p class="text-secondary">Loading…</p>
}
else if (PortalScopeError is not null)
{
    <p class="text-danger">@PortalScopeError</p>
}
else
{
    @if (!string.IsNullOrEmpty(Banner))
    {
        <div class="alert alert-info" role="status">@Banner</div>
    }

    @if (ActivePairingCode is not null)
    {
        <div class="alert alert-primary">
            <strong>Pairing code (expires @ActivePairingCode.ExpiresUtc.ToLocalTime().ToString("g"))</strong>
            <div class="mt-2 font-monospace fs-4 user-select-all">@ActivePairingCode.Code</div>
            <p class="small mb-0 mt-2">
                On the protected PC, run the <a href="@InstallerUrl" target="_blank" rel="noopener">desktop installer</a> — the <strong>Pair this PC</strong> wizard opens after setup (Start Menu → ScamAlert if you skipped it).
                The code is single-use and expires in about 15 minutes.
            </p>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="h5">Add a PC</h2>
            <div class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">Display name</label>
                    <input class="form-control" @bind="NewDeviceName" disabled="@Busy" />
                </div>
                <div class="col-md-4">
                    <button type="button" class="btn btn-primary" disabled="@Busy" @onclick="AddDeviceAsync">Add device</button>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Computer</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in DeviceList)
                {
                    <tr>
                        <td>@d.DeviceName</td>
                        <td>@(d.HasIngestKey ? "Connected" : "Needs pairing")</td>
                        <td class="text-nowrap">
                            <button type="button" class="btn btn-sm btn-outline-primary" disabled="@Busy"
                                    @onclick="() => CreatePairingCodeAsync(d.Id)">
                                Pair PC
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card border-0 sa-muted-panel">
        <div class="card-body small text-secondary">
            <p class="mb-2"><strong>Easiest setup:</strong> click <em>Pair PC</em> above, then on their Windows computer run the installer and enter the code in the <strong>Pair this PC</strong> wizard (also in the Start Menu under ScamAlert).</p>
            <p class="mb-0">
                <a class="btn btn-link btn-sm ps-0" href="@InstallerUrl" target="_blank" rel="noopener">Download the Windows installer</a>
            </p>
        </div>
    </div>
}

@using ScamAlert.Api.Contracts
@using ScamAlert.Api.Services.Portal
@using ScamAlert.Api.Services.Pairing
@using Microsoft.Extensions.Options
@using ScamAlert.Api.Services.Web
@inject IPortalDeviceService DeviceService
@inject IDevicePairingService PairingService
@inject IOptions<WebSiteOptions> WebOptions

@code {
    private List<PortalDeviceResponse> DeviceList { get; } = [];
    private DevicePairingCodeResponse? ActivePairingCode { get; set; }
    private string NewDeviceName { get; set; } = "My PC";
    private string? Banner { get; set; }
    private bool Busy { get; set; }
    private string InstallerUrl => WebOptions.Value.InstallerDownloadUrl;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (CustomerId is not null)
        {
            await ReloadAsync();
        }
    }

    private async Task ReloadAsync()
    {
        DeviceList.Clear();
        DeviceList.AddRange(await DeviceService.ListAsync(CustomerId!.Value, default));
    }

    private async Task AddDeviceAsync()
    {
        Busy = true;
        Banner = null;
        try
        {
            var created = await DeviceService.CreateAsync(
                CustomerId!.Value,
                new CreatePortalDeviceRequest(NewDeviceName, null),
                default);
            await ReloadAsync();
            ActivePairingCode = await PairingService.CreateCodeAsync(CustomerId!.Value, created.Id, default);
            Banner = ActivePairingCode is null
                ? "Device added."
                : "Device added. Enter the code below on their Windows PC.";
        }
        catch (Exception ex)
        {
            Banner = ex.Message;
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task CreatePairingCodeAsync(Guid deviceId)
    {
        Busy = true;
        Banner = null;
        ActivePairingCode = null;
        try
        {
            ActivePairingCode = await PairingService.CreateCodeAsync(CustomerId!.Value, deviceId, default);
            Banner = ActivePairingCode is null ? "Device not found." : "Enter this code on the PC you are protecting.";
        }
        catch (Exception ex)
        {
            Banner = ex.Message;
        }
        finally
        {
            Busy = false;
        }
    }

}
