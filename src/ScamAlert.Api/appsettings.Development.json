{
  "Authentication": {
    "Provider": "JwtBearer",
    "Jwt": {
      "Issuer": "ScamAlert.Api",
      "Audience": "ScamAlert.Client",
      "SigningKey": "DEV_ONLY_SIGNING_KEY_CHANGE_BEFORE_PRODUCTION_12345",
      "AccessTokenMinutes": 240,
      "RequireHttpsMetadata": false
    },
    "Lockout": {
      "MaxFailedAttempts": 10,
      "LockoutMinutes": 5
    },
    "BootstrapAdmin": {
      "Enabled": true,
      "Username": "operator",
      "Password": "dev-password",
      "Roles": [ "admin", "operator" ]
    }
  },
  "Twilio": {
    "ValidateWebhookSignatures": false
  },
  "Stripe": {
    "SkipPaymentForDevelopment": true
  },
  "Web": {
    "PublicBaseUrl": "https://localhost:7091"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
