@page "/dashboard"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>My account</PageTitle>

@if (Loading)
{
    <p class="text-secondary">Loading…</p>
}
else if (Customer is null)
{
    <p class="text-danger">Could not load your account.</p>
}
else
{
    <h1 class="h3 mb-4">Welcome, @Customer.Name</h1>
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Trusted contacts</h2>
                    <p class="small text-secondary">@Customer.ContactCount on file</p>
                    <a class="btn btn-sm btn-outline-primary" href="/contacts">Manage contacts</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Protected PCs</h2>
                    <p class="small text-secondary">@Customer.DeviceCount registered</p>
                    <a class="btn btn-sm btn-outline-primary" href="/devices">Manage devices</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Alerts</h2>
                    <p class="small text-secondary">Review suspicious access attempts</p>
                    <a class="btn btn-sm btn-outline-primary" href="/alerts">View alerts</a>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5">Subscription</h2>
            <p class="mb-2"><span class="text-muted">Plan</span> <strong>@Customer.PlanCode</strong></p>
            <p class="mb-3"><span class="text-muted">Status</span> <strong>@Customer.SubscriptionStatus</strong></p>
            <a class="btn btn-primary me-2" href="/billing">Billing</a>
            <a class="btn btn-outline-secondary" href="@InstallerUrl" target="_blank" rel="noopener">Installer download</a>
        </div>
    </div>
}

@using Microsoft.EntityFrameworkCore
@using ScamAlert.Api.Services.Auth
@using ScamAlert.Api.Services.Web
@using ScamAlert.Data
@inject IDbContextFactory<ScamAlertDbContext> DbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IOptions<WebSiteOptions> WebOptions

@code {
    private bool Loading { get; set; } = true;
    private CustomerVm? Customer { get; set; }
    private string InstallerUrl => WebOptions.Value.InstallerDownloadUrl;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var idText = state.User.FindFirst(AuthClaimTypes.CustomerId)?.Value;
        if (!Guid.TryParse(idText, out var customerId))
        {
            Loading = false;
            return;
        }

        await using var db = await DbContextFactory.CreateDbContextAsync();
        Customer = await db.Customers.AsNoTracking()
            .Where(x => x.Id == customerId)
            .Select(x => new CustomerVm(
                x.Name,
                x.Contacts.Count,
                x.Devices.Count(c => c.IsActive),
                x.Subscriptions.OrderByDescending(s => s.StartsUtc).Select(s => s.PlanCode).FirstOrDefault() ?? "—",
                x.Subscriptions.OrderByDescending(s => s.StartsUtc).Select(s => s.Status.ToString()).FirstOrDefault() ?? "—"))
            .SingleOrDefaultAsync();
        Loading = false;
    }

    private sealed record CustomerVm(
        string Name,
        int ContactCount,
        int DeviceCount,
        string PlanCode,
        string SubscriptionStatus);
}
