@inject IOptions<WebSiteOptions> WebOptions

<footer class="site-footer border-top mt-auto py-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-5">
                <div class="fw-semibold text-dark mb-2">ScamAlert</div>
                <p class="small text-secondary mb-0">
                    We help you watch the PCs that matter—parents, grandparents, and family—so suspicious remote access
                    does not go unnoticed while you are away.
                </p>
            </div>
            <div class="col-md-3">
                <div class="fw-semibold small text-dark mb-2">Product</div>
                <ul class="list-unstyled small mb-0">
                    <li><a href="/how-it-works">How it works</a></li>
                    <li><a href="/pricing">Pricing</a></li>
                    <li><a href="/faq">FAQ</a></li>
                    <li><a href="/signup">Sign up</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <div class="fw-semibold small text-dark mb-2">Legal &amp; support</div>
                <ul class="list-unstyled small mb-2">
                    <li><a href="/privacy">Privacy policy</a></li>
                    <li><a href="/terms">Terms of service</a></li>
                    <li><a href="/cookies">Cookie notice</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
                <p class="small text-secondary mb-0">
                    <a href="mailto:@SupportEmail">@SupportEmail</a>
                </p>
            </div>
        </div>
        <hr class="my-3" />
        <p class="small text-muted text-center mb-0">
            &copy; @DateTime.UtcNow.Year @LegalEntityName. United States. Not legal advice; see Terms.
        </p>
    </div>
</footer>

@code {
    private string LegalEntityName => WebOptions.Value.LegalEntityName;
    private string SupportEmail => WebOptions.Value.SupportEmail;
}
