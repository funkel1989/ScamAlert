@page "/reset-password"
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Reset password</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <h1 class="h3 mb-3">Choose a new password</h1>
        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger">@Error</div>
        }
        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="alert alert-success">@Message</div>
            <a class="btn btn-primary" href="/login">Log in</a>
        }
        else if (string.IsNullOrWhiteSpace(Token))
        {
            <p class="text-danger">Missing reset token. Use the link from your email.</p>
        }
        else
        {
            <EditForm Model="Model" OnValidSubmit="SubmitAsync" FormName="reset-password">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">New password</label>
                    <InputText type="password" class="form-control" @bind-Value="Model.Password" autocomplete="new-password" />
                    <div class="form-text">@PasswordPolicy.RequirementsDescription</div>
                </div>
                <button class="btn btn-primary w-100" type="submit" disabled="@Busy">Update password</button>
            </EditForm>
        }
    </div>
</div>

@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using ScamAlert.Api.Contracts
@inject HttpClient Http
@inject NavigationManager Navigation

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private bool Busy { get; set; }
    private string? Message { get; set; }
    private string? Error { get; set; }
    private ResetForm Model { get; } = new();

    private async Task SubmitAsync()
    {
        Busy = true;
        Error = null;
        try
        {
            if (!PasswordPolicy.TryValidate(Model.Password, out var passwordError))
            {
                Error = passwordError;
                return;
            }

            var response = await Http.PostAsJsonAsync(
                "/api/account/reset-password",
                new ResetPasswordRequest(Token!, Model.Password));

            if (response.IsSuccessStatusCode)
            {
                Message = "Password updated. You can log in now.";
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Error = body.Contains("error", StringComparison.OrdinalIgnoreCase)
                    ? TryReadError(body) ?? "Invalid or expired reset link."
                    : "Invalid or expired reset link.";
            }
        }
        finally
        {
            Busy = false;
        }
    }

    private static string? TryReadError(string json)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("error", out var err))
            {
                return err.GetString();
            }
        }
        catch
        {
            // ignore
        }

        return null;
    }

    private sealed class ResetForm
    {
        [Required, MinLength(10)]
        public string Password { get; set; } = "";
    }
}
