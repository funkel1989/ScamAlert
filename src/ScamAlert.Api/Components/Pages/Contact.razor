@page "/contact"
@attribute [AllowAnonymous]

<PageMeta Title="Contact ScamAlert"
          Description="Get help with ScamAlert, billing, and account questions."
          CanonicalPath="/contact" />

<h1 class="h3 mb-3">Contact us</h1>
<p class="text-secondary">
    We are a small team helping families watch over older loved ones' Windows PCs. Reach out for help with signup,
    installation, billing, or alerts.
</p>

<div class="card border-0 shadow-sm col-lg-8">
    <div class="card-body">
        <h2 class="h6">Email support</h2>
        <p class="mb-3">
            <a class="fs-5" href="mailto:@SupportEmail">@SupportEmail</a>
        </p>
        <p class="small text-secondary mb-0">
            Include your account email and a short description of the issue. For billing disputes, mention the charge date shown in your
            payment receipt. We aim to respond within a few business days.
        </p>
    </div>
</div>

<ul class="small text-secondary mt-4 col-lg-8">
    <li>Privacy requests: see our <a href="/privacy">privacy policy</a> and email @SupportEmail with the subject line “Privacy request”.</li>
    <li>SMS not arriving: confirm the contact phone is a valid US number (e.g. (555) 555-0100) and listed as active in your dashboard.</li>
    <li>Legal entity: @LegalEntityName (United States)</li>
</ul>

@inject IOptions<WebSiteOptions> WebOptions

@code {
    private string SupportEmail => WebOptions.Value.SupportEmail;
    private string LegalEntityName => WebOptions.Value.LegalEntityName;
}
