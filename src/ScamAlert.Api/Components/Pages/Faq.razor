@page "/faq"
@attribute [AllowAnonymous]

<PageMeta Title="FAQ — ScamAlert"
          Description="Common questions about protecting a loved one's PC, SMS alerts to you, and the $7.99/month license."
          CanonicalPath="/faq" />

<h1 class="h3 mb-4">Frequently asked questions</h1>

<div class="accordion" id="faqAccordion">
    @foreach (var item in Items)
    {
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button @(item.Open ? null : "collapsed")" type="button"
                        @onclick="() => Toggle(item)">
                    @item.Question
                </button>
            </h2>
            <div class="accordion-collapse collapse @(item.Open ? "show" : "")">
                <div class="accordion-body text-secondary">@item.Answer</div>
            </div>
        </div>
    }
</div>

<p class="mt-4 mb-0">
    Still have questions? <a href="/contact">Contact us</a> or read <a href="/how-it-works">how it works</a>.
</p>

@code {
    private List<FaqItem> Items { get; } =
    [
        new("Who is ScamAlert for?",
            "Anyone who wants to watch a Windows PC used by someone they care for—often an older parent or grandparent—especially when you cannot be there in person."),
        new("Do they need to use ScamAlert day to day?",
            "No. You sign up, install on their PC, and receive the text alerts. They do not need to log in regularly or check a website."),
        new("What phone number should I enter?",
            "A U.S. mobile number in the usual format, like (888) 888-8888."),
        new("Why does checkout ask for a billing address?",
            "Our secure payment page collects the billing address tied to your card. That helps prevent fraud. You can also add or update an address later under Billing in your account."),
        new("Is this a family or multi-seat plan?",
            "No. One $7.99/month license is tied to your account. You register their PC under it and list who gets texts (usually you, plus an optional backup)."),
        new("What does ScamAlert actually watch?",
            "Attempts to reach the PC over remote connection paths that scammers often use—not everything on the computer. Think of it as an early heads-up, not a replacement for antivirus software."),
        new("Who gets the text messages?",
            "Only the contacts you add—typically your phone and maybe a spouse or sibling. We do not sell your alert list to marketers."),
        new("Do I need permission to install on their PC?",
            "Yes. Install only on computers you own or where the user has given you clear permission. Talk with your loved one about why you are adding protection."),
        new("Will this stop every scam?",
            "No product can. ScamAlert helps you notice suspicious remote access sooner. Good security habits still matter."),
        new("How are passwords stored?",
            "We never store your actual password. It is protected using industry-standard encryption on our servers."),
        new("What password rules apply?",
            "At least 10 characters, including an uppercase letter, a number, and a special character (such as ! or #)."),
        new("Does it read my email or browsing history?",
            "No. We only collect what we need to send alerts and run your account."),
        new("What countries do you support?",
            "The service is designed for United States customers (USD billing, US-oriented compliance). Contact us if you need other regions."),
        new("How do I cancel?",
            "Use Billing in your account after sign-in to manage payment or cancel. See our Terms for details."),
    ];

    private void Toggle(FaqItem item) => item.Open = !item.Open;

    private sealed class FaqItem(string question, string answer)
    {
        public string Question { get; } = question;
        public string Answer { get; } = answer;
        public bool Open { get; set; }
    }
}
