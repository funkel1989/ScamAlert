@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Log in</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <h1 class="h3 mb-3">Log in</h1>
        @if (ShowWelcome)
        {
            <div class="alert alert-success small">Account created—sign in to open your dashboard.</div>
        }
        <p class="text-secondary small">Sign in with the email and password you used when you subscribed.</p>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }
        <form method="post" action="/login/sign-in">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@(ReturnUrl ?? string.Empty)" />
            <div class="mb-3">
                <label class="form-label" for="login-email">Email</label>
                <input id="login-email"
                       name="email"
                       type="email"
                       class="form-control"
                       autocomplete="username"
                       maxlength="@EmailAddressValidator.MaxLength"
                       value="@Email"
                       required />
            </div>
            <div class="mb-3">
                <label class="form-label" for="login-password">Password</label>
                <input id="login-password"
                       name="password"
                       type="password"
                       class="form-control"
                       autocomplete="current-password"
                       required />
            </div>
            <button class="btn btn-primary w-100" type="submit">Log in</button>
        </form>
        <p class="mt-3 small text-center"><a href="/forgot-password">Forgot password?</a></p>
        @if (MicrosoftLoginEnabled)
        {
            <div class="text-center my-3 text-muted small">or</div>
            <a class="btn btn-outline-secondary w-100" href="/external/microsoft?returnUrl=@Uri.EscapeDataString(ReturnUrl ?? "/dashboard")">Sign in with Microsoft</a>
        }
    </div>
</div>

@using ScamAlert.Api.Services.Validation
@inject IConfiguration Configuration

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "welcome")]
    public bool ShowWelcome { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorCode { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    private bool MicrosoftLoginEnabled =>
        !string.IsNullOrWhiteSpace(Configuration["Authentication:Microsoft:ClientId"]);

    private string? ErrorMessage => ErrorCode switch
    {
        "locked" => "Account is temporarily locked. Try again later.",
        "invalid" => "Invalid email or password.",
        "checkout" => "Payment could not be confirmed. Sign in if you already have an account.",
        _ => null
    };
}
