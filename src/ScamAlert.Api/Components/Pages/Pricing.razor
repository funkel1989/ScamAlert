@page "/pricing"
@attribute [AllowAnonymous]

<PageMeta Title="Pricing — $7.99/month to protect a loved one's PC"
          Description="One plan: $7.99 per month. You manage the account, install on their Windows PC, and get SMS when remote access looks suspicious."
          CanonicalPath="/pricing" />

<h1 class="h3 mb-2">Simple pricing</h1>
<p class="text-secondary mb-4">
    One license for caregivers in the United States (@MarketRegion)—you subscribe, protect their PC, and receive the alerts.
    <strong>@PriceLabel</strong>, billed through secure online checkout. Cancel anytime from your account. Your card’s billing address is collected on the payment page.
</p>

@if (Tier is not null)
{
    <div class="row justify-content-center mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-primary">
                <div class="card-body d-flex flex-column p-4">
                    <h2 class="h4">@Tier.DisplayName</h2>
                    <p class="display-6 fw-semibold text-sa-accent mb-2">@PriceLabel</p>
                    <p class="text-secondary">@(Tier.MarketingSummary ?? "Monitor your Windows PCs and alert contacts you trust.")</p>
                    <ul class="small text-secondary flex-grow-1">
                        @foreach (var feature in Tier.MarketingFeatures)
                        {
                            <li class="mb-1">@feature</li>
                        }
                    </ul>
                    <a class="btn btn-primary btn-lg" href="/signup">Protect someone I care for</a>
                </div>
            </div>
        </div>
    </div>
}

<div class="small text-secondary col-lg-8 mx-auto text-center">
    <p class="mb-1">Subscriptions renew until canceled in your billing portal. See <a href="/terms">Terms of service</a>.</p>
    <p class="mb-0">SMS alerts require numbers you are authorized to use; message and data rates may apply.</p>
</div>

@inject IOptions<BillingOptions> Billing

@code {
    private BillingTierOptions? Tier => Billing.Value.Tiers.FirstOrDefault();
    private string MarketRegion => Billing.Value.MarketRegion;
    private string PriceLabel => Tier?.MonthlyPriceLabel ?? "$7.99 per month (USD)";
}
