@using Microsoft.AspNetCore.Components.Authorization

<div class="d-flex flex-wrap gap-2 align-items-center">
    <a class="btn btn-link" href="/">Home</a>
    <AuthorizeView>
        <NotAuthorized>
            <a class="btn btn-link" href="/how-it-works">How it works</a>
            <a class="btn btn-link" href="/pricing">Pricing</a>
            <a class="btn btn-link" href="/faq">FAQ</a>
            <a class="btn btn-link" href="/signup">Sign up</a>
        </NotAuthorized>
    </AuthorizeView>
    <AuthorizeView>
        <Authorized>
            <a class="btn btn-link" href="/dashboard">Account</a>
            <a class="btn btn-link" href="/contacts">Contacts</a>
            <a class="btn btn-link" href="/devices">Devices</a>
            <a class="btn btn-link" href="/alerts">Alerts</a>
            <a class="btn btn-link" href="/billing">Billing</a>
            <a class="btn btn-outline-secondary btn-sm" href="/logout">Log out</a>
        </Authorized>
        <NotAuthorized>
            <a class="btn btn-outline-primary btn-sm" href="/login">Log in</a>
        </NotAuthorized>
    </AuthorizeView>
</div>
