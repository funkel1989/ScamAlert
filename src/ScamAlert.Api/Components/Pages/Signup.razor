@page "/signup"
@attribute [AllowAnonymous]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Sign up</PageTitle>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1 class="h3 mb-2">Create your account</h1>
        <p class="text-secondary mb-4">
            One license at $7.99/month—you manage everything. Add <strong>your</strong> phone for alerts, then install on
            the PC of someone you care for so you know when a scammer tries remote access. They do not need to monitor it.
        </p>
        <p class="small text-secondary mb-4">
            After this form you’ll finish payment online. Your card’s billing address is collected on the secure payment page.
        </p>
        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="alert @(IsError ? "alert-danger" : "alert-info")">@Message</div>
        }
        <EditForm Model="Model" OnValidSubmit="SubmitAsync" FormName="signup">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">First name</label>
                    <InputText class="form-control" @bind-Value="Model.FirstName" autocomplete="given-name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Last name</label>
                    <InputText class="form-control" @bind-Value="Model.LastName" autocomplete="family-name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email (also your login)</label>
                    <input type="email"
                           class="form-control"
                           autocomplete="email"
                           maxlength="@EmailAddressValidator.MaxLength"
                           @bind="Model.Email"
                           @bind:event="oninput" />
                    <ValidationMessage For="@(() => Model.Email)" />
                    <EmailValidationHint Email="@Model.Email" ShowWhenEmpty="true" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Password</label>
                    <input type="password"
                           class="form-control"
                           autocomplete="new-password"
                           @bind="Model.Password"
                           @bind:event="oninput" />
                    <PasswordRequirementsChecklist Password="@Model.Password" ShowWhenEmpty="true" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Plan</label>
                    @if (Plans.Count <= 1)
                    {
                        <p class="form-control-plaintext fw-semibold mb-0">@SinglePlanDisplay</p>
                    }
                    else
                    {
                        <InputSelect class="form-select" @bind-Value="Model.PlanCode">
                            @foreach (var plan in Plans)
                            {
                                <option value="@plan.PlanCode">@plan.DisplayName</option>
                            }
                        </InputSelect>
                    }
                </div>
                <div class="col-12"><hr /></div>
                <div class="col-md-6">
                    <label class="form-label">Your mobile for alerts</label>
                    <UsPhoneInput @bind-Value="Model.PrimaryPhone" Autocomplete="tel" />
                    <div class="form-text">10-digit U.S. mobile number, e.g. (888) 888-8888.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Secondary contact (optional)</label>
                    <InputText class="form-control" @bind-Value="Model.SecondaryContactName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Backup mobile (optional)</label>
                    <UsPhoneInput @bind-Value="Model.SecondaryPhone" Autocomplete="tel" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Their PC (display name)</label>
                    <InputText class="form-control" @bind-Value="Model.DeviceName" />
                    <div class="form-text">Example: Mom's laptop — install our app on <em>their</em> Windows PC after signup.</div>
                </div>
                <div class="col-12"><hr /></div>
                <div class="col-12">
                    <h2 class="h6">Agreements</h2>
                    <div class="form-check mb-2">
                        <InputCheckbox class="form-check-input" @bind-Value="Model.AcceptTerms" id="acceptTerms" />
                        <label class="form-check-label" for="acceptTerms">
                            I agree to the <a href="/terms" target="_blank">Terms of service</a>.
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <InputCheckbox class="form-check-input" @bind-Value="Model.AcceptPrivacy" id="acceptPrivacy" />
                        <label class="form-check-label" for="acceptPrivacy">
                            I have read the <a href="/privacy" target="_blank">Privacy policy</a>.
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <InputCheckbox class="form-check-input" @bind-Value="Model.AcceptSmsConsent" id="acceptSms" />
                        <label class="form-check-label" for="acceptSms">
                            I confirm I have permission to add the mobile numbers above for automated security alerts by SMS.
                            Message and data rates may apply. Message frequency varies. This is not marketing spam from ScamAlert staff.
                        </label>
                    </div>
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="Model.ConfirmInstallPermission" id="confirmInstall" />
                        <label class="form-check-label" for="confirmInstall">
                            I will only install protection on PCs I own or where the user has given me clear permission.
                        </label>
                    </div>
                </div>
            </div>
            <button class="btn btn-primary mt-4" type="submit" disabled="@Busy">Continue to payment</button>
        </EditForm>
        @if (!string.IsNullOrEmpty(PendingSignInTicket))
        {
            <form method="post" action="/signup/complete" id="signup-complete-form" class="d-none">
                <AntiforgeryToken />
                <input type="hidden" name="ticket" value="@PendingSignInTicket" />
            </form>
        }
    </div>
</div>

@using ScamAlert.Api.Services.Auth
@using ScamAlert.Api.Services.Validation
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using System.Text.Json
@using ScamAlert.Api.Contracts
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime Js
@inject IOptions<BillingOptions> BillingOptions
@inject IOptions<WebSiteOptions> WebOptions

@code {
    private bool Busy { get; set; }
    private string? Message { get; set; }
    private bool IsError { get; set; }
    private string? PendingSignInTicket { get; set; }
    private bool _completeFormSubmitted;
    private List<SignupPlanResponse> Plans { get; } = [];

    private string SinglePlanDisplay
    {
        get
        {
            var tier = BillingOptions.Value.Tiers.FirstOrDefault();
            var name = Plans.FirstOrDefault()?.DisplayName ?? tier?.DisplayName ?? "Personal license";
            var price = tier?.MonthlyPriceLabel ?? "$7.99 per month";
            return $"{name} — {price}";
        }
    }

    private SignupFormModel Model { get; } = new();

    [SupplyParameterFromQuery(Name = "plan")]
    public string? PlanQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var plans = await Http.GetFromJsonAsync<List<SignupPlanResponse>>("/api/signup/plans");
            if (plans is { Count: > 0 })
            {
                Plans.AddRange(plans);
            }
        }
        catch
        {
            Plans.Add(new SignupPlanResponse("pro", "Personal license"));
        }

        if (!string.IsNullOrWhiteSpace(PlanQuery) && Plans.Any(p => p.PlanCode.Equals(PlanQuery, StringComparison.OrdinalIgnoreCase)))
        {
            Model.PlanCode = PlanQuery.Trim();
        }
        else if (Plans.Count > 0)
        {
            Model.PlanCode = Plans[0].PlanCode;
        }
    }

    private async Task SubmitAsync()
    {
        Busy = true;
        Message = null;
        IsError = false;

        if (!Model.AcceptTerms || !Model.AcceptPrivacy || !Model.AcceptSmsConsent || !Model.ConfirmInstallPermission)
        {
            IsError = true;
            Message = "Please accept all agreements before continuing.";
            Busy = false;
            return;
        }

        if (!EmailAddressValidator.TryValidate(Model.Email, out _, out var emailError))
        {
            IsError = true;
            Message = emailError;
            Busy = false;
            return;
        }

        if (!PasswordPolicy.TryValidate(Model.Password, out var passwordError))
        {
            IsError = true;
            Message = passwordError;
            Busy = false;
            return;
        }

        var accountName = $"{Model.FirstName.Trim()} {Model.LastName.Trim()}".Trim();
        if (string.IsNullOrWhiteSpace(accountName))
        {
            IsError = true;
            Message = "First and last name are required.";
            Busy = false;
            return;
        }

        if (!UsPhoneNumber.TryNormalize(Model.PrimaryPhone, out _, out var primaryPhoneError))
        {
            IsError = true;
            Message = primaryPhoneError;
            Busy = false;
            return;
        }

        if (!string.IsNullOrWhiteSpace(Model.SecondaryPhone)
            && !UsPhoneNumber.TryNormalize(Model.SecondaryPhone, out _, out var secondaryPhoneError))
        {
            IsError = true;
            Message = secondaryPhoneError;
            Busy = false;
            return;
        }

        try
        {
            var contacts = new List<CreateContactRequest>
            {
                new(accountName, Model.PrimaryPhone.Trim(), 1)
            };
            if (!string.IsNullOrWhiteSpace(Model.SecondaryPhone) && !string.IsNullOrWhiteSpace(Model.SecondaryContactName))
            {
                contacts.Add(new CreateContactRequest(
                    Model.SecondaryContactName.Trim(),
                    Model.SecondaryPhone.Trim(),
                    2));
            }

            var deviceId = $"device-{Guid.NewGuid():N}";
            var devices = new List<CreateDeviceRequest>
            {
                new(Model.DeviceName.Trim(), deviceId)
            };

            var payload = new SelfServeSignupRequest(
                accountName,
                Model.Email.Trim(),
                Model.Password,
                Model.PlanCode.Trim(),
                contacts,
                devices,
                new SignupConsents(
                    Model.AcceptTerms,
                    Model.AcceptPrivacy,
                    Model.AcceptSmsConsent,
                    Model.ConfirmInstallPermission,
                    WebOptions.Value.LegalEffectiveDate));

            var response = await Http.PostAsJsonAsync("/api/signup", payload);
            if (!response.IsSuccessStatusCode)
            {
                IsError = true;
                Message = await response.Content.ReadAsStringAsync();
                return;
            }

            var doc = await response.Content.ReadFromJsonAsync<JsonElement>();
            if (doc.TryGetProperty("signInTicket", out var ticketElement) &&
                ticketElement.ValueKind == JsonValueKind.String &&
                !string.IsNullOrWhiteSpace(ticketElement.GetString()))
            {
                PendingSignInTicket = ticketElement.GetString();
                return;
            }

            var url = doc.GetProperty("checkoutUrl").GetString();
            if (!string.IsNullOrWhiteSpace(url))
            {
                NavigationManager.NavigateTo(url, forceLoad: true);
            }
        }
        finally
        {
            Busy = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrEmpty(PendingSignInTicket) || _completeFormSubmitted)
        {
            return;
        }

        _completeFormSubmitted = true;
        await Js.InvokeVoidAsync("scamAlertSubmitForm", "signup-complete-form");
    }

    public sealed class SignupFormModel
    {
        [Required, MaxLength(100)]
        public string FirstName { get; set; } = string.Empty;

        [Required, MaxLength(100)]
        public string LastName { get; set; } = string.Empty;

        [Required]
        [ValidEmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required, MinLength(10)]
        public string Password { get; set; } = string.Empty;

        [Required, MaxLength(100)]
        public string PlanCode { get; set; } = "pro";

        [Required]
        public string PrimaryPhone { get; set; } = string.Empty;

        [MaxLength(200)]
        public string? SecondaryContactName { get; set; }

        [MaxLength(32)]
        public string? SecondaryPhone { get; set; }

        [Required, MaxLength(200)]
        public string DeviceName { get; set; } = "Their PC";

        public bool AcceptTerms { get; set; }
        public bool AcceptPrivacy { get; set; }
        public bool AcceptSmsConsent { get; set; }
        public bool ConfirmInstallPermission { get; set; }
    }
}
