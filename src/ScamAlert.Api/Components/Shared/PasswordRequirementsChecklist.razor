@using ScamAlert.Api.Services.Auth

@if (ShowChecklist)
{
    <ul class="sa-password-rules list-unstyled small mb-0 mt-2" aria-live="polite">
        <li class="@RuleClass(Status.MinLength)">
            <span class="sa-password-rule-icon" aria-hidden="true">@Icon(Status.MinLength)</span>
            At least @PasswordPolicy.MinLength characters
        </li>
        <li class="@RuleClass(Status.HasUppercase)">
            <span class="sa-password-rule-icon" aria-hidden="true">@Icon(Status.HasUppercase)</span>
            One uppercase letter
        </li>
        <li class="@RuleClass(Status.HasDigit)">
            <span class="sa-password-rule-icon" aria-hidden="true">@Icon(Status.HasDigit)</span>
            One number
        </li>
        <li class="@RuleClass(Status.HasSpecial)">
            <span class="sa-password-rule-icon" aria-hidden="true">@Icon(Status.HasSpecial)</span>
            One special character
        </li>
    </ul>
    @if (Status.AllMet)
    {
        <p class="small text-sa-accent mb-0 mt-2"><strong>Password meets all requirements.</strong></p>
    }
}

@code {
    [Parameter]
    public string? Password { get; set; }

    [Parameter]
    public bool ShowWhenEmpty { get; set; }

    private PasswordRequirementStatus Status => PasswordPolicy.Evaluate(Password);

    private bool ShowChecklist => ShowWhenEmpty || !string.IsNullOrEmpty(Password);

    private static string RuleClass(bool met) =>
        met ? "sa-password-rule sa-password-rule--met" : "sa-password-rule";

    private static string Icon(bool met) => met ? "✓" : "○";
}
